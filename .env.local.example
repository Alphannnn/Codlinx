# =============================================================================
# Codlinx — Local environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored. None of these are required for the marketing site to render —
# without them, the auth/admin/booking pages fall back to "demo mode" with
# seeded data and a banner indicating Supabase is not connected.
# =============================================================================

# ---- Supabase (auth + database) --------------------------------------------
# Create a project at https://supabase.com → Project settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — required for server-side admin operations only. NEVER
# expose this to the browser. Stays in .env.local on the server.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Admin gating -----------------------------------------------------------
# This single email becomes admin on first sign-in. Override per environment.
NEXT_PUBLIC_ADMIN_EMAIL=adnan.mustafa@toptal.com

# ---- Site URL ---------------------------------------------------------------
# Used for redirect callbacks on magic-link sign-in. In production set to your
# real domain (e.g. https://codlinx.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- OAuth providers (optional) --------------------------------------------
# Comma-separated list of providers actually wired up under Supabase →
# Authentication → Providers. The login page only renders buttons for the
# providers listed here, so it never shows an affordance that won't work.
#
# To enable Google:
#   1. https://console.cloud.google.com → New OAuth client (Web application)
#   2. Authorized redirect URI: https://<your-ref>.supabase.co/auth/v1/callback
#   3. Supabase → Authentication → Providers → Google → paste client ID + secret
#   4. Add `google` to the list below.
#
# To enable GitHub:
#   1. https://github.com/settings/developers → New OAuth App
#   2. Authorization callback URL: https://<your-ref>.supabase.co/auth/v1/callback
#   3. Supabase → Authentication → Providers → GitHub → paste client ID + secret
#   4. Add `github` to the list below.
NEXT_PUBLIC_OAUTH_PROVIDERS=
